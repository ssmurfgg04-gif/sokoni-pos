// Sokoni POS - KRA eTIMS Compliant Point of Sale System
// Comprehensive database schema for offline-first, two-way compliance

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE BUSINESS ENTITIES
// ============================================

model Business {
  id              String   @id @default(cuid())
  name            String
  kraPin          String   @unique                    // KRA PIN of the business
  email           String?
  phone           String?
  address         String?
  county          String?
  vatRegistered   Boolean  @default(false)
  sectorCode      String?                             // KRA business sector code
  kraUsername     String?                             // eTIMS portal credentials
  kraPassword     String?                             // Encrypted in production
  kraBranchId     String?                             // KRA branch assignment
  currentTier     String   @default("free")           // free | growth | pro
  invoiceCount    Int      @default(0)                // Track usage for freemium
  billingCycleStart DateTime @default(now())
  language        String   @default("en")             // en | sw
  currency        String   @default("KES")
  receiptFooter   String?                             // Custom receipt footer text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  products      Product[]
  invoices      Invoice[]
  customers     Customer[]
  suppliers     Supplier[]
  purchases     PurchaseRecord[]
  mpesaTransactions MpesaTransaction[]
  syncQueue     SyncQueue[]
  settings      Settings[]
  staff         Staff[]
  branches     Branch[]
}

model Product {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  description   String?
  sku           String?                              // Stock Keeping Unit
  barcode       String?
  category      String?
  unitPrice     Float                                 // Selling price
  costPrice     Float?                                // Purchase/cost price
  vatRate       Float    @default(16.0)               // VAT percentage (Kenya standard 16%)
  vatType       String   @default("VAT")              // VAT | ZERO | EXEMPT | NONTAXABLE
  itemCode      String?                              // KRA item classification code
  itemClassCode String?                              // KRA item class code
  unitOfMeasure String?                              // KRA unit of measure code
  quantity      Int      @default(0)                  // Current stock quantity
  reorderLevel  Int      @default(10)                 // Low stock alert threshold
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoiceItems  InvoiceItem[]

  @@index([businessId])
  @@index([sku])
  @@index([barcode])
}

model Customer {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  kraPin      String?                              // Buyer PIN for B2B invoices - CRITICAL
  email       String?
  phone       String?
  address     String?
  isVatRegistered Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoices    Invoice[]

  @@index([businessId])
  @@index([kraPin])
}

model Supplier {
  id              String   @id @default(cuid())
  businessId      String
  name            String
  kraPin          String?                              // Supplier KRA PIN
  email           String?
  phone           String?
  address         String?
  isEtimesCompliant Boolean @default(false)           // Whether supplier has eTIMS
  bankName        String?
  bankAccount     String?
  paybillNumber   String?                             // M-Pesa paybill
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  purchases       PurchaseRecord[]

  @@index([businessId])
  @@index([kraPin])
}

// ============================================
// INVOICE & TRANSACTION MODELS
// ============================================

model Invoice {
  id                String   @id @default(cuid())
  businessId        String
  invoiceNumber     String   @unique                   // System-generated invoice number
  kraInvoiceNumber  String?                            // KRA-assigned control number
  
  // Buyer details (critical for B2B)
  customerId        String?                            // Link to customer record
  buyerPin          String?                            // REQUIRED for B2B - buyer's KRA PIN
  buyerName         String?
  buyerAddress      String?
  
  // Invoice metadata
  issueDate         DateTime @default(now())           // Date invoice was issued
  localTimestamp    DateTime @default(now())           // Offline timestamp when created
  dueDate           DateTime?
  
  // Financial totals
  subtotal          Float    @default(0)               // Before tax
  totalVat          Float    @default(0)               // Total VAT amount
  totalAmount       Float    @default(0)               // Grand total (subtotal + VAT)
  discountAmount    Float    @default(0)
  
  // Payment
  paymentMethod     String   @default("cash")          // cash | mpesa | bank_transfer | credit
  mpesaReceiptNumber String?                           // Auto-captured from Daraja callback
  mpesaPhoneNumber  String?                            // Customer M-Pesa phone
  
  // KRA compliance fields
  status            String   @default("draft")         // draft | queued | syncing | synced | failed | cancelled
  kraSignature      String?                            // Digital signature from KRA
  kraControlNumber  String?                            // KRA control unit number
  kraQrCodeData     String?                            // QR code data from KRA
  kraInternalData   String?                            // KRA internal data (JSON string)
  
  // Error tracking & retry
  retryCount        Int      @default(0)
  maxRetries        Int      @default(5)
  lastError         String?
  lastSyncAttempt   DateTime?
  nextRetryAt       DateTime?
  
  // Receipt
  receiptPrinted    Boolean  @default(false)
  
  // Type classification
  invoiceType       String   @default("standard")      // standard | credit_note | debit_note | proforma
  relatedInvoiceId  String?                            // For credit/debit notes
  
  cancelledAt       DateTime?
  cancelReason      String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer          Customer? @relation(fields: [customerId], references: [id])
  items             InvoiceItem[]
  syncQueue         SyncQueue[]
  mpesaTransactions MpesaTransaction[]

  @@index([businessId])
  @@index([status])
  @@index([buyerPin])
  @@index([kraInvoiceNumber])
  @@index([createdAt])
}

model InvoiceItem {
  id            String   @id @default(cuid())
  invoiceId     String
  productId     String?
  
  // Product details at time of sale (snapshot)
  itemName      String
  itemCode      String?                             // KRA item code
  itemClassCode String?                             // KRA item class code
  quantity      Float                               // Supports decimal quantities
  unitPrice     Float                               // Price per unit
  unitOfMeasure String?                             // KRA unit of measure
  vatRate       Float    @default(16.0)              // VAT rate for this item
  vatAmount     Float    @default(0)                  // Calculated VAT amount
  discountRate  Float    @default(0)
  discountAmount Float   @default(0)
  lineTotal     Float                               // quantity * unitPrice - discount + vat
  
  createdAt     DateTime @default(now())

  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product       Product?  @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
}

// ============================================
// PURCHASE RECORDS (Two-Way Compliance)
// ============================================

model PurchaseRecord {
  id                String   @id @default(cuid())
  businessId        String
  
  // Supplier details
  supplierId        String?
  supplierName      String
  supplierPin       String?                            // Supplier KRA PIN
  supplierInvoiceNumber String?                       // Supplier's own invoice number
  
  // Purchase details
  purchaseDate      DateTime @default(now())
  description       String
  category          String?                            // Expense category
  
  // Financial
  subtotal          Float    @default(0)
  totalVat          Float    @default(0)
  totalAmount       Float    @default(0)
  
  // Payment
  paymentMethod     String   @default("cash")          // cash | mpesa | bank_transfer | credit
  mpesaReceiptNumber String?
  
  // Compliance
  isEtimesCompliant Boolean  @default(false)           // Does supplier invoice exist in eTIMS?
  buyerInitiated    Boolean  @default(false)           // Did we generate this on behalf of supplier?
  kraReference      String?                            // KRA reference if buyer-initiated
  
  // Document tracking
  attachmentUrl     String?                            // Scanned/uploaded invoice image
  
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier          Supplier? @relation(fields: [supplierId], references: [id])

  @@index([businessId])
  @@index([supplierPin])
  @@index([purchaseDate])
  @@index([isEtimesCompliant])
}

// ============================================
// M-PESA TRANSACTIONS
// ============================================

model MpesaTransaction {
  id                String   @id @default(cuid())
  businessId        String
  invoiceId         String?
  
  // M-Pesa details
  mpesaReceipt      String?                            // M-Pesa receipt number (unique)
  phoneNumber       String                             // Customer phone
  amount            Float
  accountReference  String?                            // Our reference
  transactionDesc   String?
  
  // STK Push tracking
  checkoutRequestId String?                            // Daraja checkout request ID
  merchantRequestId String?                            // Daraja merchant request ID
  
  // Status
  status            String   @default("pending")       // pending | processing | completed | failed | timed_out
  resultCode        String?
  resultDesc        String?
  
  // Callback data
  callbackRaw       String?                            // Raw callback JSON for debugging
  
  // Reconciliation
  reconciled        Boolean  @default(false)
  reconciledAt      DateTime?
  discrepancy       Float?                             // Amount difference if any
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice           Invoice?  @relation(fields: [invoiceId], references: [id])

  @@index([businessId])
  @@index([mpesaReceipt])
  @@index([status])
  @@index([invoiceId])
  @@index([createdAt])
}

// ============================================
// OFFLINE SYNC QUEUE
// ============================================

model SyncQueue {
  id            String   @id @default(cuid())
  businessId    String
  
  // What to sync
  entityType    String                             // invoice | purchase | customer | product
  entityId      String                             // ID of the entity to sync
  action        String                             // create | update | delete
  payload       String                             // JSON payload of the data
  
  // Sync status
  status        String   @default("pending")       // pending | in_progress | completed | failed | dead_letter
  attempts      Int      @default(0)
  maxAttempts   Int      @default(5)
  lastAttempt   DateTime?
  nextAttempt   DateTime?                          // Exponential backoff scheduled time
  lastError     String?
  
  // Priority
  priority      Int      @default(5)               // 1 (highest) - 10 (lowest)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  completedAt   DateTime?

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice       Invoice?  @relation(fields: [entityId], references: [id])

  @@index([businessId, status])
  @@index([status, nextAttempt])
  @@index([entityType, entityId])
  @@index([priority])
}

// ============================================
// SETTINGS & CONFIGURATION
// ============================================

model Settings {
  id          String   @id @default(cuid())
  businessId  String
  
  // Key-value settings store
  key         String                              // Setting key (e.g., "mpesa_consumer_key")
  value       String                              // Setting value (encrypted for secrets)
  isSecret    Boolean  @default(false)             // Mark for encryption
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, key])
  @@index([businessId])
}

// ============================================
// ANALYTICS SNAPSHOT (Daily rollup)
// ============================================

model DailySnapshot {
  id              String   @id @default(cuid())
  businessId      String
  date            DateTime
  
  // Sales metrics
  totalSales      Float    @default(0)
  totalVatCollected Float  @default(0)
  invoiceCount    Int      @default(0)
  averageInvoiceValue Float @default(0)
  
  // Purchase metrics
  totalPurchases  Float    @default(0)
  totalInputVat   Float    @default(0)
  purchaseCount   Int      @default(0)
  
  // M-Pesa metrics
  mpesaTransactionCount Int @default(0)
  mpesaTotalAmount Float   @default(0)
  mpesaReconciliationRate Float @default(0)
  
  // Compliance metrics
  syncedInvoiceCount Int   @default(0)
  failedInvoiceCount Int   @default(0)
  queuedInvoiceCount Int   @default(0)
  compliantSupplierPurchases Int @default(0)
  nonCompliantSupplierPurchases Int @default(0)
  
  createdAt       DateTime @default(now())

  @@unique([businessId, date])
  @@index([businessId, date])
}

// ============================================
// STAFF MANAGEMENT (Enterprise Tier)
// ============================================

model Staff {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  email         String?
  phone         String?
  pin           String                      // 4-digit POS login PIN
  role          String   @default("cashier") // owner | manager | cashier
  isActive      Boolean  @default(true)
  
  // Permissions
  canRefund     Boolean  @default(false)
  canDiscount   Boolean  @default(false)
  canEditPrice  Boolean  @default(false)
  canVoid       Boolean  @default(false)
  canViewReports Boolean @default(false)
  canManageStock Boolean @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business     Business @relation(fields: [businessId], references: [id])
  shifts       Shift[]

  @@index([businessId])
}

model Shift {
  id            String   @id @default(cuid())
  businessId    String
  staffId       String
  branchId      String?                     // For multi-branch
  clockIn       DateTime
  clockOut      DateTime?
  
  // Cash drawer tracking
  openingCash   Float    @default(0)
  closingCash   Float?
  expectedCash  Float?                      // Calculated from sales
  cashVariance  Float?                      // Difference = closing - expected
  cashPayments  Float    @default(0)         // Cash sales during shift
  mpesaPayments Float    @default(0)         // M-Pesa sales during shift
  
  // Performance
  invoicesCreated Int     @default(0)
  totalSales    Float    @default(0)
  refunds       Float    @default(0)
  discounts     Float    @default(0)
  
  notes         String?
  createdAt     DateTime @default(now())

  staff         Staff    @relation(fields: [staffId], references: [id])

  @@index([businessId, staffId])
  @@index([businessId, clockIn])
}

// ============================================
// BRANCH MANAGEMENT (Enterprise Tier)
// ============================================

model Branch {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  location      String?
  county        String?
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business     Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}
